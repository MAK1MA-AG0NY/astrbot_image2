{
  "script_path": {
    "description": "脚本路径",
    "hint": "默认使用插件目录下的 rcode_draw.py；也可填写绝对路径",
    "type": "string",
    "default": "rcode_draw.py"
  },
  "python_executable": {
    "description": "Python 解释器",
    "hint": "默认使用当前 AstrBot 进程的 python",
    "type": "string",
    "default": ""
  },
  "api_key": {
    "description": "API Key",
    "hint": "优先填写 Right Code 的密钥；也兼容环境变量 right_code_image2",
    "type": "string",
    "default": "",
    "obvious_hint": true
  },
  "model": {
    "description": "模型名",
    "type": "string",
    "default": "gpt-image-2"
  },
  "size": {
    "description": "图片尺寸",
    "hint": "例如 1024x1024；留空则不传",
    "type": "string",
    "default": ""
  },
  "output": {
    "description": "输出文件路径",
    "hint": "留空则走脚本默认保存目录；填入文件路径可指定保存位置",
    "type": "string",
    "default": ""
  },
  "keep_url": {
    "description": "仅保留 URL",
    "hint": "开启后直接返回图片 URL，不下载到本地",
    "type": "bool",
    "default": false
  },
  "timeout_seconds": {
    "description": "脚本执行超时（秒）",
    "type": "int",
    "default": 180
  }
}
